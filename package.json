{
  "name": "boondmanager-mcp-server",
  "version": "1.13.1",
  "description": "MCP Server for BoondManager API - 169 tools, 12 prompts, 21 resources (ERP/CRM)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "boondmanager-mcp-server": "dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "manifest.json",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benoitkochversusmind/boondmanager-mcp-vsm.git"
  },
  "bugs": {
    "url": "https://github.com/benoitkochversusmind/boondmanager-mcp-vsm/issues"
  },
  "homepage": "https://github.com/benoitkochversusmind/boondmanager-mcp-vsm#readme",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "boondmanager",
    "esn",
    "crm",
    "versusmind"
  ],
  "author": "Versusmind",
  "license": "Apache-2.0",
  "dependencies": {
    "@azure/identity": "^4.4.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
